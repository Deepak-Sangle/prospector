{
  "name": "prospector",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "check": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "start": "node --watch app.ts",
    "lint": "npx @biomejs/biome check .",
    "lint:fix": "npx @biomejs/biome check --write .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --test 'tests/**/*.test.ts'"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/google": "^2.0.0",
    "@ai-sdk/google-vertex": "^3.0.146",
    "@composio/core": "^0.6.11",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@slack/bolt": "^4.7.3",
    "ai": "^5.0.0",
    "bridgly": "^0.1.1",
    "croner": "^10.0.1",
    "dotenv": "~17.4.2",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^24.0.0",
    "prettier": "3.9.4",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3"
  }
}
